#!/usr/bin/env bash
set -euo pipefail

SOURCE="manual"
if [ "${1:-}" = "--source" ]; then
  SOURCE="${2:-manual}"
fi

ENV_FILE="{{ hermes_config_sync_env_path }}"
if [ -f "$ENV_FILE" ]; then
  set -a
  # shellcheck disable=SC1090
  . "$ENV_FILE"
  set +a
fi

: "${HERMES_HOME:?HERMES_HOME is required}"
: "${HERMES_CONFIG_REPO:?HERMES_CONFIG_REPO is required}"
: "${HERMES_CONFIG_BRANCH:=main}"
: "${HERMES_CONFIG_DIR:?HERMES_CONFIG_DIR is required}"
: "${HERMES_CONFIG_GIT_TOKEN:?HERMES_CONFIG_GIT_TOKEN is required}"
: "${HERMES_USER:=hermes}"
: "${HERMES_GROUP:=hermes}"
: "${HERMES_CONFIG_APPLY:={{ hermes_config_apply_path }}}"
: "${HERMES_VENV_PATH:={{ hermes_venv_path }}}"
: "${HERMES_GATEWAY_SERVICE:=hermes-gateway.service}"
: "${HERMES_CONFIG_RESTART_PATTERNS:=^config/|^profiles/|^plugins/|^rules/|^kanban/|^cron/}"
: "${HERMES_CONFIG_COMMIT_USER_NAME:=holybaechu}"
: "${HERMES_CONFIG_COMMIT_USER_EMAIL:=holybaechu@proton.me}"

LOCK=/run/hermes-config-sync.lock
mkdir -p /run
exec 9>"$LOCK"
flock -x 9

ASKPASS="{{ hermes_config_askpass_path }}"
GIT_ENV=(
  "HOME=$HERMES_HOME"
  "GIT_ASKPASS=$ASKPASS"
  "GIT_TERMINAL_PROMPT=0"
  "HERMES_CONFIG_GIT_TOKEN=$HERMES_CONFIG_GIT_TOKEN"
)

run_as_hermes() {
  runuser -u "$HERMES_USER" -- env "${GIT_ENV[@]}" "$@"
}

git_cmd() {
  run_as_hermes git -C "$HERMES_CONFIG_DIR" "$@"
}

changed_files_file=$(mktemp)
cleanup() {
  rm -f "$changed_files_file"
}
trap cleanup EXIT

mkdir -p "$HERMES_HOME"
chown "$HERMES_USER:$HERMES_GROUP" "$HERMES_HOME"

if [ ! -d "$HERMES_CONFIG_DIR/.git" ]; then
  if [ -e "$HERMES_CONFIG_DIR" ] && [ "$(find "$HERMES_CONFIG_DIR" -mindepth 1 -maxdepth 1 | wc -l)" -ne 0 ]; then
    printf 'hermes-config directory exists but is not an empty git checkout: %s\n' "$HERMES_CONFIG_DIR" >&2
    exit 1
  fi
  mkdir -p "$(dirname "$HERMES_CONFIG_DIR")"
  chown "$HERMES_USER:$HERMES_GROUP" "$(dirname "$HERMES_CONFIG_DIR")"
  run_as_hermes git clone --branch "$HERMES_CONFIG_BRANCH" "$HERMES_CONFIG_REPO" "$HERMES_CONFIG_DIR"
  printf 'cloned=true\n'
fi

chown -R "$HERMES_USER:$HERMES_GROUP" "$HERMES_CONFIG_DIR"
run_as_hermes git config --global --add safe.directory "$HERMES_CONFIG_DIR" >/dev/null 2>&1 || true
git_cmd config user.name "$HERMES_CONFIG_COMMIT_USER_NAME"
git_cmd config user.email "$HERMES_CONFIG_COMMIT_USER_EMAIL"

git_cmd fetch origin "$HERMES_CONFIG_BRANCH"

before=""
if before=$(git_cmd rev-parse --verify HEAD 2>/dev/null); then
  :
else
  before=""
fi

if [ -n "$(git_cmd status --porcelain)" ]; then
  git_cmd add -A
  if git_cmd diff --cached --quiet; then
    :
  else
    git_cmd commit -m "chore: sync live Hermes config" -m "Source: ${SOURCE}" >/dev/null
    printf 'committed_local=true\n'
  fi
fi

remote="$(git_cmd rev-parse "origin/$HERMES_CONFIG_BRANCH")"
local="$(git_cmd rev-parse HEAD)"

if [ "$local" = "$remote" ]; then
  :
elif git_cmd merge-base --is-ancestor "$local" "$remote"; then
  git_cmd diff --name-only "$local" "$remote" >> "$changed_files_file" || true
  git_cmd merge --ff-only "$remote"
  printf 'fast_forwarded=true\n'
elif git_cmd merge-base --is-ancestor "$remote" "$local"; then
  git_cmd push origin "HEAD:$HERMES_CONFIG_BRANCH"
  printf 'pushed=true\n'
else
  if git_cmd rebase "$remote"; then
    git_cmd push origin "HEAD:$HERMES_CONFIG_BRANCH"
    printf 'rebased=true\n'
  else
    git_cmd rebase --abort || true
    printf 'conflict=true\n' >&2
    exit 2
  fi
fi

after="$(git_cmd rev-parse HEAD)"
if [ -n "$before" ] && [ "$before" != "$after" ]; then
  git_cmd diff --name-only "$before" "$after" >> "$changed_files_file" || true
elif [ -z "$before" ]; then
  git_cmd ls-files >> "$changed_files_file" || true
fi

sort -u "$changed_files_file" -o "$changed_files_file"

apply_output=""
if [ -x "$HERMES_CONFIG_APPLY" ]; then
  PYTHON="/usr/bin/python3"
  if [ -x "$HERMES_VENV_PATH/bin/python" ]; then
    PYTHON="$HERMES_VENV_PATH/bin/python"
  fi
  if apply_output="$($PYTHON "$HERMES_CONFIG_APPLY")"; then
    printf '%s\n' "$apply_output"
  else
    printf '%s\n' "$apply_output" >&2
    exit 3
  fi
fi

restart_required=false
if [ -s "$changed_files_file" ] && grep -Eq "$HERMES_CONFIG_RESTART_PATTERNS" "$changed_files_file"; then
  restart_required=true
fi
if printf '%s\n' "$apply_output" | grep -q '^restart_required=true$'; then
  restart_required=true
fi

if [ "$restart_required" = true ]; then
  systemctl try-restart "$HERMES_GATEWAY_SERVICE" || true
  printf 'restart_handler=try-restart:%s\n' "$HERMES_GATEWAY_SERVICE"
else
  printf 'restart_handler=skipped\n'
fi

if [ -s "$changed_files_file" ]; then
  printf 'changed_files<<EOF\n'
  cat "$changed_files_file"
  printf 'EOF\n'
fi
printf 'sync_ok source=%s rev=%s\n' "$SOURCE" "$after"

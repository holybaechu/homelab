#!/usr/bin/env python3
from pathlib import Path
import copy
import json
import os
import shutil
import tempfile

import yaml


HERMES_HOME = Path("{{ hermes_home }}")
CONFIG_PATH = HERMES_HOME / "config.yaml"
PROFILES_ROOT = HERMES_HOME / "profiles"
DESIRED_COMPRESSION_PROVIDER = "{{ hermes_auxiliary_compression_provider }}"
DESIRED_COMPRESSION_TIMEOUT = {{ hermes_auxiliary_compression_timeout | int }}
DESIRED_COMPRESSION_THRESHOLD = {{ hermes_compression_threshold | float }}
DESIRED_CODEX_GPT55_AUTORAISE = {{ (hermes_compression_codex_gpt55_autoraise | bool) | ternary('True', 'False') }}
DESIRED_WEB_SEARCH_BACKEND = "{{ hermes_web_search_backend }}"
DESIRED_WEB_EXTRACT_BACKEND = "{{ hermes_web_extract_backend }}"
DESIRED_BROWSER_CLOUD_PROVIDER = "{{ hermes_browser_cloud_provider }}"
DESIRED_BROWSER_AUTO_LOCAL_FOR_PRIVATE_URLS = {{ (hermes_browser_auto_local_for_private_urls | bool) | ternary('True', 'False') }}
DESIRED_MEMORY_PROVIDER = "{{ hermes_memory_provider | default('') }}".strip()
DESIRED_DISCORD_TOOLSETS = ["hermes-discord", "browser", "kanban"]
DESIRED_PLUGINS = ["newrrow-browser-login"]
DESIRED_KANBAN = json.loads({{ hermes_kanban | default({}) | to_json | to_json }})
DESIRED_PROFILES = json.loads({{ hermes_profiles | default([]) | to_json | to_json }})
DESIRED_DEFAULT_CONTROL_PLANE = json.loads({{ hermes_default_control_plane_guidance | default("") | to_json | to_json }})
DESIRED_KANBAN_CARD_TEMPLATE = json.loads({{ hermes_kanban_card_template | default("") | to_json | to_json }})
DESIRED_KANBAN_REVIEW_REQUIRED_POLICY = json.loads({{ hermes_kanban_review_required_policy | default("") | to_json | to_json }})
DESIRED_KANBAN_BOARDS = json.loads({{ hermes_kanban_boards | default([]) | to_json | to_json }})
SKILLS_ROOT = HERMES_HOME / "skills"
SERVICE_USER = "{{ hermes_user }}"
SERVICE_GROUP = "{{ hermes_group }}"
MANAGED_SOUL_START = "<!-- HOMELAB-HERMES-PROFILE-ROLE:START -->"
MANAGED_SOUL_END = "<!-- HOMELAB-HERMES-PROFILE-ROLE:END -->"
MANAGED_DEFAULT_SOUL_START = "<!-- HOMELAB-HERMES-DEFAULT-CONTROL-PLANE:START -->"
MANAGED_DEFAULT_SOUL_END = "<!-- HOMELAB-HERMES-DEFAULT-CONTROL-PLANE:END -->"


def ensure_dict(parent, key):
    current = parent.get(key)
    if isinstance(current, dict):
        return current
    current = {}
    parent[key] = current
    return current


def set_list(parent, key, desired_items):
    current = parent.get(key)
    desired = list(desired_items)
    parent[key] = desired
    return current != desired


def set_value(mapping, key, value):
    if mapping.get(key) == value:
        return False
    mapping[key] = value
    return True


def load_yaml_mapping(path, fallback=None):
    if fallback is None:
        fallback = {}
    if not path.exists():
        return copy.deepcopy(fallback)
    loaded = yaml.safe_load(path.read_text(encoding="utf-8")) or {}
    if not isinstance(loaded, dict):
        raise SystemExit(f"{path} must contain a YAML mapping")
    return loaded


def atomic_write_text(path, content, *, default_mode=0o600):
    path.parent.mkdir(parents=True, exist_ok=True)
    original_stat = path.stat() if path.exists() else None
    fd, tmp_name = tempfile.mkstemp(
        prefix=f".{path.name}.",
        suffix=".tmp",
        dir=str(path.parent),
        text=True,
    )
    tmp_path = Path(tmp_name)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            handle.write(content)

        if original_stat is not None:
            if hasattr(os, "chown"):
                os.chown(tmp_path, original_stat.st_uid, original_stat.st_gid)
            os.chmod(tmp_path, original_stat.st_mode & 0o777)
        else:
            if hasattr(os, "chown"):
                shutil.chown(tmp_path, user=SERVICE_USER, group=SERVICE_GROUP)
            os.chmod(tmp_path, default_mode)

        tmp_path.replace(path)
    finally:
        if tmp_path.exists():
            tmp_path.unlink()


def write_yaml_if_changed(path, data, *, default_mode=0o600):
    rendered = yaml.safe_dump(data, sort_keys=False, allow_unicode=True)
    if path.exists() and path.read_text(encoding="utf-8") == rendered:
        return False
    atomic_write_text(path, rendered, default_mode=default_mode)
    return True


def apply_common_runtime(config, *, browser_cloud_provider=None, browser_auto_local_for_private_urls=None):
    auxiliary = ensure_dict(config, "auxiliary")
    compression = ensure_dict(auxiliary, "compression")
    runtime_compression = ensure_dict(config, "compression")
    web = ensure_dict(config, "web")
    browser = ensure_dict(config, "browser")

    changed = False
    changed |= set_value(compression, "provider", DESIRED_COMPRESSION_PROVIDER)
    changed |= set_value(compression, "model", "")
    changed |= set_value(compression, "timeout", DESIRED_COMPRESSION_TIMEOUT)

    changed |= set_value(runtime_compression, "threshold", DESIRED_COMPRESSION_THRESHOLD)
    changed |= set_value(
        runtime_compression,
        "codex_gpt55_autoraise",
        DESIRED_CODEX_GPT55_AUTORAISE,
    )

    changed |= set_value(web, "search_backend", DESIRED_WEB_SEARCH_BACKEND)
    changed |= set_value(web, "extract_backend", DESIRED_WEB_EXTRACT_BACKEND)
    changed |= set_value(web, "backend", "")

    cloud_provider = browser_cloud_provider or DESIRED_BROWSER_CLOUD_PROVIDER
    auto_local = (
        DESIRED_BROWSER_AUTO_LOCAL_FOR_PRIVATE_URLS
        if browser_auto_local_for_private_urls is None
        else bool(browser_auto_local_for_private_urls)
    )
    changed |= set_value(browser, "cloud_provider", cloud_provider)
    changed |= set_value(browser, "auto_local_for_private_urls", auto_local)
    return changed


def apply_default_runtime(config):
    changed = apply_common_runtime(config)
    plugins = ensure_dict(config, "plugins")
    platform_toolsets = ensure_dict(config, "platform_toolsets")
    kanban = ensure_dict(config, "kanban")
    memory = ensure_dict(config, "memory")

    for key, value in DESIRED_KANBAN.items():
        changed |= set_value(kanban, key, value)

    changed |= set_list(
        platform_toolsets,
        "discord",
        DESIRED_DISCORD_TOOLSETS,
    )

    changed |= set_list(plugins, "enabled", DESIRED_PLUGINS)
    changed |= set_value(memory, "provider", DESIRED_MEMORY_PROVIDER)
    return changed


def env_value(value):
    if isinstance(value, bool):
        return "true" if value else "false"
    return str(value)


def ensure_env_values(path, values):
    if path.exists():
        lines = path.read_text(encoding="utf-8").splitlines()
    else:
        lines = [
            "# Per-profile non-secret runtime overrides managed by homelab IaC.",
            "# API keys and tokens are inherited from the gateway service environment.",
        ]
    rendered = {key: env_value(value) for key, value in values.items()}
    seen = set()
    out = []
    changed = False
    for line in lines:
        stripped = line.strip()
        replaced = False
        for key, value in rendered.items():
            if stripped.startswith(f"{key}=") or stripped.startswith(f"export {key}="):
                if key in seen:
                    changed = True
                    replaced = True
                    break
                newline = f"{key}={value}"
                if line != newline:
                    changed = True
                out.append(newline)
                seen.add(key)
                replaced = True
                break
        if not replaced:
            out.append(line)
    for key, value in rendered.items():
        if key not in seen:
            if out and out[-1].strip():
                pass
            out.append(f"{key}={value}")
            changed = True
    new_text = "\n".join(out).rstrip() + "\n"
    if not path.exists() or path.read_text(encoding="utf-8") != new_text:
        atomic_write_text(path, new_text, default_mode=0o600)
        changed = True
    return changed


def format_bullets(items):
    return "\n".join(f"- {str(item).strip()}" for item in (items or []) if str(item).strip()) or "- None specified."


def replace_managed_block(path, start_marker, end_marker, block, *, default_mode=0o644):
    current = path.read_text(encoding="utf-8") if path.exists() else ""
    if start_marker in current and end_marker in current:
        before, rest = current.split(start_marker, 1)
        _, after = rest.split(end_marker, 1)
        new_text = before.rstrip() + "\n\n" + block + after.lstrip("\n")
    else:
        new_text = current.rstrip() + "\n\n" + block
    if current != new_text:
        atomic_write_text(path, new_text, default_mode=default_mode)
        return True
    return False


def ensure_default_soul():
    if not DESIRED_DEFAULT_CONTROL_PLANE:
        return False
    block = (
        f"{MANAGED_DEFAULT_SOUL_START}\n"
        "# Homelab-managed default control-plane guidance\n\n"
        f"{DESIRED_DEFAULT_CONTROL_PLANE}\n\n"
        "Default may use Kanban directly for triage, but complex execution should be routed to "
        "the orchestrator or specialist profiles using the managed card template.\n"
        f"{MANAGED_DEFAULT_SOUL_END}\n"
    )
    return replace_managed_block(
        HERMES_HOME / "SOUL.md",
        MANAGED_DEFAULT_SOUL_START,
        MANAGED_DEFAULT_SOUL_END,
        block,
    )


def ensure_policy_files():
    policies_dir = HERMES_HOME / "kanban" / "policies"
    routing_rows = []
    for profile in DESIRED_PROFILES:
        routing = profile.get("routing") or {}
        handles = "; ".join(str(item).strip() for item in routing.get("handles") or [] if str(item).strip())
        avoid = "; ".join(str(item).strip() for item in routing.get("avoid") or [] if str(item).strip())
        skills = ", ".join(str(item).strip() for item in profile.get("required_skills") or [] if str(item).strip())
        routing_rows.append(
            f"| `{profile['name']}` | `{routing.get('default_board', 'default')}` | {handles or '—'} | {avoid or '—'} | {skills or '—'} |"
        )
    board_rows = []
    for board in DESIRED_KANBAN_BOARDS:
        board_rows.append(
            f"| `{board['slug']}` | {board.get('name', board['slug'])} | {board.get('description', '')} |"
        )
    routing_matrix = (
        "# Homelab Hermes Kanban routing matrix\n\n"
        "This file is generated by homelab IaC. It is the routing contract for the orchestrator profile.\n\n"
        "## Boards\n\n"
        "| Board | Name | Purpose |\n| --- | --- | --- |\n"
        + "\n".join(board_rows)
        + "\n\n## Profile lanes\n\n"
        "| Profile | Default board | Handles | Avoids | Required skills |\n| --- | --- | --- | --- | --- |\n"
        + "\n".join(routing_rows)
        + "\n"
    )
    files = {
        "routing-matrix.md": routing_matrix,
        "card-template.md": "# Homelab Hermes Kanban card template\n\n" + DESIRED_KANBAN_CARD_TEMPLATE.strip() + "\n",
        "review-required.md": "# Homelab Hermes review-required policy\n\n" + DESIRED_KANBAN_REVIEW_REQUIRED_POLICY.strip() + "\n",
    }
    changed = False
    for name, content in files.items():
        changed |= write_text_if_changed(policies_dir / name, content, default_mode=0o644)
    return changed


def write_text_if_changed(path, content, *, default_mode=0o644):
    if path.exists() and path.read_text(encoding="utf-8") == content:
        return False
    atomic_write_text(path, content, default_mode=default_mode)
    return True


def find_skill_source(skill_name):
    if not skill_name or not SKILLS_ROOT.is_dir():
        return None
    direct_matches = [
        SKILLS_ROOT / skill_name,
        *SKILLS_ROOT.glob(f"*/{skill_name}"),
    ]
    for candidate in direct_matches:
        if (candidate / "SKILL.md").is_file():
            return candidate
    for skill_file in SKILLS_ROOT.rglob("SKILL.md"):
        try:
            for line in skill_file.read_text(encoding="utf-8").splitlines()[:40]:
                if line.startswith("name:"):
                    name = line.split(":", 1)[1].strip().strip('"\'')
                    if name == skill_name:
                        return skill_file.parent
                    break
        except OSError:
            continue
    return None


def tree_fingerprint(root):
    if not root.exists():
        return None
    fingerprint = []
    for path in sorted(root.rglob("*")):
        rel = path.relative_to(root).as_posix()
        if path.is_dir():
            fingerprint.append((rel, "dir", None))
        elif path.is_file():
            fingerprint.append((rel, "file", path.read_bytes()))
    return fingerprint


def sync_skill_tree(src, dest):
    if tree_fingerprint(src) == tree_fingerprint(dest):
        return False
    if dest.exists():
        shutil.rmtree(dest)
    dest.parent.mkdir(parents=True, exist_ok=True)
    shutil.copytree(src, dest)
    if hasattr(shutil, "chown"):
        for path in [dest, *dest.rglob("*")]:
            try:
                shutil.chown(path, user=SERVICE_USER, group=SERVICE_GROUP)
            except LookupError:
                break
    return True


def ensure_profile_required_skills(profile_dir, profile):
    changed = False
    required = list(profile.get("required_skills") or [])
    if not required:
        return False
    for skill_name in required:
        source = find_skill_source(skill_name)
        if source is None:
            raise SystemExit(f"missing required skill source in {SKILLS_ROOT}: {skill_name}")
        rel = source.relative_to(SKILLS_ROOT)
        changed |= sync_skill_tree(source, profile_dir / "skills" / rel)
    return changed


def ensure_profile_soul(profile_dir, profile):
    name = profile["name"]
    description = profile.get("description", "").strip()
    routing = profile.get("routing") or {}
    required_skills = profile.get("required_skills") or []
    completion_contract = profile.get("completion_contract") or []
    if name == DESIRED_KANBAN.get("orchestrator_profile", "orchestrator"):
        behavior = (
            "You are the Kanban orchestrator. Use the managed routing matrix and card template, "
            "decompose broad goals into small linked cards, choose specialist assignees, attach "
            "relevant required skills, comment with routing rationale, and avoid implementation work."
        )
    else:
        behavior = (
            "You are a Kanban worker profile. On spawn, call kanban_show first, do only work that "
            "matches this profile role, keep evidence in comments/metadata, heartbeat during long work, "
            "and finish with kanban_complete or kanban_block."
        )
    review_rule = (
        "For code, IaC, deployment, account-impacting browser, or risky sandbox changes, add a structured "
        "kanban_comment and block with `review-required: ...` unless the card explicitly says review is not needed."
        if profile.get("review_required_for_changes")
        else "This profile may complete non-changing routing/research cards when the evidence contract is satisfied."
    )
    block = (
        f"{MANAGED_SOUL_START}\n"
        f"# Homelab-managed profile role: {name}\n\n"
        f"Role summary: {description}\n\n"
        "## Behavior\n"
        f"{behavior}\n\n"
        "## Routing lane\n"
        f"Default board: `{routing.get('default_board', 'default')}`\n\n"
        "Handles:\n"
        f"{format_bullets(routing.get('handles'))}\n\n"
        "Avoids:\n"
        f"{format_bullets(routing.get('avoid'))}\n\n"
        "## Required skills to attach or load when relevant\n"
        f"{format_bullets(required_skills)}\n\n"
        "## Completion contract\n"
        f"{format_bullets(completion_contract)}\n\n"
        "## Review gate\n"
        f"{review_rule}\n"
        f"{MANAGED_SOUL_END}\n"
    )
    return replace_managed_block(
        profile_dir / "SOUL.md",
        MANAGED_SOUL_START,
        MANAGED_SOUL_END,
        block,
    )

def apply_profile_runtime(profile, base_config):
    name = profile["name"]
    profile_dir = PROFILES_ROOT / name
    if not profile_dir.is_dir():
        # The Ansible profile-create task is responsible for creating the
        # directory. Skipping here keeps this helper non-destructive if a
        # profile create failed earlier.
        return False

    config_path = profile_dir / "config.yaml"
    config = load_yaml_mapping(config_path, fallback=base_config)
    changed = apply_common_runtime(
        config,
        browser_cloud_provider=profile.get("browser_cloud_provider"),
        browser_auto_local_for_private_urls=profile.get("browser_auto_local_for_private_urls"),
    )

    platform_toolsets = ensure_dict(config, "platform_toolsets")
    desired_cli_toolsets = list(profile.get("cli_toolsets") or [])
    if platform_toolsets != {"cli": desired_cli_toolsets}:
        config["platform_toolsets"] = {"cli": desired_cli_toolsets}
        changed = True

    plugins = ensure_dict(config, "plugins")
    desired_plugins = list(profile.get("plugins_enabled") or [])
    changed |= set_value(plugins, "enabled", desired_plugins)

    kanban = ensure_dict(config, "kanban")
    changed |= set_value(kanban, "dispatch_in_gateway", False)
    changed |= set_value(kanban, "failure_limit", DESIRED_KANBAN.get("failure_limit", 2))
    changed |= set_value(
        kanban,
        "dispatch_stale_timeout_seconds",
        DESIRED_KANBAN.get("dispatch_stale_timeout_seconds", 14400),
    )

    changed |= write_yaml_if_changed(config_path, config)
    changed |= write_yaml_if_changed(
        profile_dir / "profile.yaml",
        {
            "description": profile.get("description", "").strip(),
            "description_auto": False,
            "routing": profile.get("routing") or {},
            "required_skills": list(profile.get("required_skills") or []),
            "completion_contract": list(profile.get("completion_contract") or []),
            "review_required_for_changes": bool(profile.get("review_required_for_changes", False)),
        },
        default_mode=0o644,
    )
    changed |= ensure_profile_soul(profile_dir, profile)
    changed |= ensure_profile_required_skills(profile_dir, profile)
    changed |= ensure_env_values(
        profile_dir / ".env",
        {
            "BROWSERBASE_PROXIES": profile.get("browserbase_proxies", False),
            "BROWSERBASE_ADVANCED_STEALTH": profile.get(
                "browserbase_advanced_stealth",
                "{{ hermes_browserbase_advanced_stealth | string | lower }}",
            ),
        },
    )
    return changed


def main():
    config = load_yaml_mapping(CONFIG_PATH)
    changed = apply_default_runtime(config)
    changed |= write_yaml_if_changed(CONFIG_PATH, config)
    changed |= ensure_default_soul()
    changed |= ensure_policy_files()

    # Use the just-normalized default config as the non-secret profile base.
    # Per-profile .env files below intentionally contain only non-secret
    # overrides; workers inherit service credentials from the gateway process.
    base_config = copy.deepcopy(config)
    for profile in DESIRED_PROFILES:
        changed |= apply_profile_runtime(profile, base_config)

    print("changed" if changed else "ok")


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
from pathlib import Path
import os
import shutil
import tempfile

import yaml


CONFIG_PATH = Path("{{ hermes_home }}/config.yaml")
DESIRED_COMPRESSION_PROVIDER = "{{ hermes_auxiliary_compression_provider }}"
DESIRED_WEB_SEARCH_BACKEND = "{{ hermes_web_search_backend }}"
DESIRED_WEB_EXTRACT_BACKEND = "{{ hermes_web_extract_backend }}"
SERVICE_USER = "{{ hermes_user }}"
SERVICE_GROUP = "{{ hermes_group }}"


def ensure_dict(parent, key):
    current = parent.get(key)
    if isinstance(current, dict):
        return current
    current = {}
    parent[key] = current
    return current


def main():
    if CONFIG_PATH.exists():
        original_stat = CONFIG_PATH.stat()
        config = yaml.safe_load(CONFIG_PATH.read_text(encoding="utf-8")) or {}
    else:
        original_stat = None
        config = {}

    if not isinstance(config, dict):
        raise SystemExit(f"{CONFIG_PATH} must contain a YAML mapping")

    auxiliary = ensure_dict(config, "auxiliary")
    compression = ensure_dict(auxiliary, "compression")
    web = ensure_dict(config, "web")

    changed = False
    if compression.get("provider") != DESIRED_COMPRESSION_PROVIDER:
        compression["provider"] = DESIRED_COMPRESSION_PROVIDER
        changed = True
    if compression.get("model") != "":
        compression["model"] = ""
        changed = True

    if web.get("search_backend") != DESIRED_WEB_SEARCH_BACKEND:
        web["search_backend"] = DESIRED_WEB_SEARCH_BACKEND
        changed = True
    if web.get("extract_backend") != DESIRED_WEB_EXTRACT_BACKEND:
        web["extract_backend"] = DESIRED_WEB_EXTRACT_BACKEND
        changed = True
    if web.get("backend") != "":
        web["backend"] = ""
        changed = True

    if not changed:
        print("ok")
        return

    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    rendered = yaml.safe_dump(config, sort_keys=False, allow_unicode=True)
    fd, tmp_name = tempfile.mkstemp(
        prefix=f".{CONFIG_PATH.name}.",
        suffix=".tmp",
        dir=str(CONFIG_PATH.parent),
        text=True,
    )
    tmp_path = Path(tmp_name)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            handle.write(rendered)

        if original_stat is not None:
            if hasattr(os, "chown"):
                os.chown(tmp_path, original_stat.st_uid, original_stat.st_gid)
            os.chmod(tmp_path, original_stat.st_mode & 0o777)
        else:
            if hasattr(os, "chown"):
                shutil.chown(tmp_path, user=SERVICE_USER, group=SERVICE_GROUP)
            os.chmod(tmp_path, 0o600)

        tmp_path.replace(CONFIG_PATH)
    finally:
        if tmp_path.exists():
            tmp_path.unlink()

    print("changed")


if __name__ == "__main__":
    main()

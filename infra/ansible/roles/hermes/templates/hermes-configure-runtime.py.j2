#!/usr/bin/env python3
from pathlib import Path
import copy
import json
import os
import shutil
import tempfile

import yaml


HERMES_HOME = Path("{{ hermes_home }}")
CONFIG_PATH = HERMES_HOME / "config.yaml"
PROFILES_ROOT = HERMES_HOME / "profiles"
DESIRED_COMPRESSION_PROVIDER = "{{ hermes_auxiliary_compression_provider }}"
DESIRED_COMPRESSION_TIMEOUT = {{ hermes_auxiliary_compression_timeout | int }}
DESIRED_COMPRESSION_THRESHOLD = {{ hermes_compression_threshold | float }}
DESIRED_CODEX_GPT55_AUTORAISE = {{ (hermes_compression_codex_gpt55_autoraise | bool) | ternary('True', 'False') }}
DESIRED_WEB_SEARCH_BACKEND = "{{ hermes_web_search_backend }}"
DESIRED_WEB_EXTRACT_BACKEND = "{{ hermes_web_extract_backend }}"
DESIRED_BROWSER_CLOUD_PROVIDER = "{{ hermes_browser_cloud_provider }}"
DESIRED_BROWSER_AUTO_LOCAL_FOR_PRIVATE_URLS = {{ (hermes_browser_auto_local_for_private_urls | bool) | ternary('True', 'False') }}
DESIRED_DISCORD_TOOLSETS = ["hermes-discord", "browser", "kanban"]
DESIRED_PLUGINS = ["newrrow-browser-login"]
DESIRED_KANBAN = json.loads({{ hermes_kanban | default({}) | to_json | to_json }})
DESIRED_PROFILES = json.loads({{ hermes_profiles | default([]) | to_json | to_json }})
SERVICE_USER = "{{ hermes_user }}"
SERVICE_GROUP = "{{ hermes_group }}"
MANAGED_SOUL_START = "<!-- HOMELAB-HERMES-PROFILE-ROLE:START -->"
MANAGED_SOUL_END = "<!-- HOMELAB-HERMES-PROFILE-ROLE:END -->"


def ensure_dict(parent, key):
    current = parent.get(key)
    if isinstance(current, dict):
        return current
    current = {}
    parent[key] = current
    return current


def ensure_list(parent, key, default_items):
    current = parent.get(key)
    if isinstance(current, list):
        return current
    current = list(default_items)
    parent[key] = current
    return current


def set_value(mapping, key, value):
    if mapping.get(key) == value:
        return False
    mapping[key] = value
    return True


def load_yaml_mapping(path, fallback=None):
    if fallback is None:
        fallback = {}
    if not path.exists():
        return copy.deepcopy(fallback)
    loaded = yaml.safe_load(path.read_text(encoding="utf-8")) or {}
    if not isinstance(loaded, dict):
        raise SystemExit(f"{path} must contain a YAML mapping")
    return loaded


def atomic_write_text(path, content, *, default_mode=0o600):
    path.parent.mkdir(parents=True, exist_ok=True)
    original_stat = path.stat() if path.exists() else None
    fd, tmp_name = tempfile.mkstemp(
        prefix=f".{path.name}.",
        suffix=".tmp",
        dir=str(path.parent),
        text=True,
    )
    tmp_path = Path(tmp_name)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            handle.write(content)

        if original_stat is not None:
            if hasattr(os, "chown"):
                os.chown(tmp_path, original_stat.st_uid, original_stat.st_gid)
            os.chmod(tmp_path, original_stat.st_mode & 0o777)
        else:
            if hasattr(os, "chown"):
                shutil.chown(tmp_path, user=SERVICE_USER, group=SERVICE_GROUP)
            os.chmod(tmp_path, default_mode)

        tmp_path.replace(path)
    finally:
        if tmp_path.exists():
            tmp_path.unlink()


def write_yaml_if_changed(path, data, *, default_mode=0o600):
    rendered = yaml.safe_dump(data, sort_keys=False, allow_unicode=True)
    if path.exists() and path.read_text(encoding="utf-8") == rendered:
        return False
    atomic_write_text(path, rendered, default_mode=default_mode)
    return True


def apply_common_runtime(config, *, browser_cloud_provider=None, browser_auto_local_for_private_urls=None):
    auxiliary = ensure_dict(config, "auxiliary")
    compression = ensure_dict(auxiliary, "compression")
    runtime_compression = ensure_dict(config, "compression")
    web = ensure_dict(config, "web")
    browser = ensure_dict(config, "browser")

    changed = False
    changed |= set_value(compression, "provider", DESIRED_COMPRESSION_PROVIDER)
    changed |= set_value(compression, "model", "")
    changed |= set_value(compression, "timeout", DESIRED_COMPRESSION_TIMEOUT)

    changed |= set_value(runtime_compression, "threshold", DESIRED_COMPRESSION_THRESHOLD)
    changed |= set_value(
        runtime_compression,
        "codex_gpt55_autoraise",
        DESIRED_CODEX_GPT55_AUTORAISE,
    )

    changed |= set_value(web, "search_backend", DESIRED_WEB_SEARCH_BACKEND)
    changed |= set_value(web, "extract_backend", DESIRED_WEB_EXTRACT_BACKEND)
    changed |= set_value(web, "backend", "")

    cloud_provider = browser_cloud_provider or DESIRED_BROWSER_CLOUD_PROVIDER
    auto_local = (
        DESIRED_BROWSER_AUTO_LOCAL_FOR_PRIVATE_URLS
        if browser_auto_local_for_private_urls is None
        else bool(browser_auto_local_for_private_urls)
    )
    changed |= set_value(browser, "cloud_provider", cloud_provider)
    changed |= set_value(browser, "auto_local_for_private_urls", auto_local)
    return changed


def apply_default_runtime(config):
    changed = apply_common_runtime(config)
    plugins = ensure_dict(config, "plugins")
    platform_toolsets = ensure_dict(config, "platform_toolsets")
    kanban = ensure_dict(config, "kanban")

    for key, value in DESIRED_KANBAN.items():
        changed |= set_value(kanban, key, value)

    discord_toolsets_existing = platform_toolsets.get("discord")
    discord_toolsets = ensure_list(
        platform_toolsets,
        "discord",
        DESIRED_DISCORD_TOOLSETS,
    )
    if not isinstance(discord_toolsets_existing, list):
        changed = True
    for toolset in DESIRED_DISCORD_TOOLSETS:
        if toolset not in discord_toolsets:
            discord_toolsets.append(toolset)
            changed = True

    plugins_enabled_existing = plugins.get("enabled")
    plugins_enabled = ensure_list(plugins, "enabled", DESIRED_PLUGINS)
    if not isinstance(plugins_enabled_existing, list):
        changed = True
    for plugin in DESIRED_PLUGINS:
        if plugin not in plugins_enabled:
            plugins_enabled.append(plugin)
            changed = True
    return changed


def env_value(value):
    if isinstance(value, bool):
        return "true" if value else "false"
    return str(value)


def ensure_env_values(path, values):
    if path.exists():
        lines = path.read_text(encoding="utf-8").splitlines()
    else:
        lines = [
            "# Per-profile non-secret runtime overrides managed by homelab IaC.",
            "# API keys and tokens are inherited from the gateway service environment.",
        ]
    rendered = {key: env_value(value) for key, value in values.items()}
    seen = set()
    out = []
    changed = False
    for line in lines:
        stripped = line.strip()
        replaced = False
        for key, value in rendered.items():
            if stripped.startswith(f"{key}=") or stripped.startswith(f"export {key}="):
                newline = f"{key}={value}"
                if line != newline:
                    changed = True
                out.append(newline)
                seen.add(key)
                replaced = True
                break
        if not replaced:
            out.append(line)
    for key, value in rendered.items():
        if key not in seen:
            if out and out[-1].strip():
                pass
            out.append(f"{key}={value}")
            changed = True
    new_text = "\n".join(out).rstrip() + "\n"
    if not path.exists() or path.read_text(encoding="utf-8") != new_text:
        atomic_write_text(path, new_text, default_mode=0o600)
        changed = True
    return changed


def ensure_profile_soul(profile_dir, profile):
    name = profile["name"]
    description = profile.get("description", "").strip()
    if name == DESIRED_KANBAN.get("orchestrator_profile", "orchestrator"):
        behavior = (
            "You are the Kanban orchestrator. Decompose broad user goals into "
            "small linked Kanban cards, choose assignees from the configured "
            "specialist profiles, comment with routing rationale, and avoid "
            "doing implementation work yourself."
        )
    else:
        behavior = (
            "You are a Kanban worker profile. When spawned for a Kanban task, "
            "first read the card through kanban_show, do only the work that "
            "matches this profile role, leave durable comments/metadata, and "
            "finish with kanban_complete or kanban_block."
        )
    block = (
        f"{MANAGED_SOUL_START}\n"
        f"# Homelab-managed profile role: {name}\n\n"
        f"Role summary: {description}\n\n"
        f"{behavior}\n"
        f"{MANAGED_SOUL_END}\n"
    )
    soul_path = profile_dir / "SOUL.md"
    current = soul_path.read_text(encoding="utf-8") if soul_path.exists() else ""
    if MANAGED_SOUL_START in current and MANAGED_SOUL_END in current:
        before, rest = current.split(MANAGED_SOUL_START, 1)
        _, after = rest.split(MANAGED_SOUL_END, 1)
        new_text = before.rstrip() + "\n\n" + block + after.lstrip("\n")
    else:
        new_text = current.rstrip() + "\n\n" + block
    if current != new_text:
        atomic_write_text(soul_path, new_text, default_mode=0o644)
        return True
    return False


def apply_profile_runtime(profile, base_config):
    name = profile["name"]
    profile_dir = PROFILES_ROOT / name
    if not profile_dir.is_dir():
        # The Ansible profile-create task is responsible for creating the
        # directory. Skipping here keeps this helper non-destructive if a
        # profile create failed earlier.
        return False

    config_path = profile_dir / "config.yaml"
    config = load_yaml_mapping(config_path, fallback=base_config)
    changed = apply_common_runtime(
        config,
        browser_cloud_provider=profile.get("browser_cloud_provider"),
        browser_auto_local_for_private_urls=profile.get("browser_auto_local_for_private_urls"),
    )

    platform_toolsets = ensure_dict(config, "platform_toolsets")
    desired_cli_toolsets = list(profile.get("cli_toolsets") or [])
    if platform_toolsets != {"cli": desired_cli_toolsets}:
        config["platform_toolsets"] = {"cli": desired_cli_toolsets}
        changed = True

    plugins = ensure_dict(config, "plugins")
    desired_plugins = list(profile.get("plugins_enabled") or [])
    changed |= set_value(plugins, "enabled", desired_plugins)

    kanban = ensure_dict(config, "kanban")
    changed |= set_value(kanban, "dispatch_in_gateway", False)
    changed |= set_value(kanban, "failure_limit", DESIRED_KANBAN.get("failure_limit", 2))
    changed |= set_value(
        kanban,
        "dispatch_stale_timeout_seconds",
        DESIRED_KANBAN.get("dispatch_stale_timeout_seconds", 14400),
    )

    changed |= write_yaml_if_changed(config_path, config)
    changed |= write_yaml_if_changed(
        profile_dir / "profile.yaml",
        {
            "description": profile.get("description", "").strip(),
            "description_auto": False,
        },
        default_mode=0o644,
    )
    changed |= ensure_profile_soul(profile_dir, profile)
    changed |= ensure_env_values(
        profile_dir / ".env",
        {
            "BROWSERBASE_PROXIES": profile.get("browserbase_proxies", False),
            "BROWSERBASE_ADVANCED_STEALTH": profile.get(
                "browserbase_advanced_stealth",
                "{{ hermes_browserbase_advanced_stealth | string | lower }}",
            ),
        },
    )
    return changed


def main():
    config = load_yaml_mapping(CONFIG_PATH)
    changed = apply_default_runtime(config)
    changed |= write_yaml_if_changed(CONFIG_PATH, config)

    # Use the just-normalized default config as the non-secret profile base.
    # Per-profile .env files below intentionally contain only non-secret
    # overrides; workers inherit service credentials from the gateway process.
    base_config = copy.deepcopy(config)
    for profile in DESIRED_PROFILES:
        changed |= apply_profile_runtime(profile, base_config)

    print("changed" if changed else "ok")


if __name__ == "__main__":
    main()

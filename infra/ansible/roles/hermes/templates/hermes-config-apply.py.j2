#!/usr/bin/env python3
from __future__ import annotations

import filecmp
import grp
import json
import os
from pathlib import Path
import pwd
import shutil
import stat
import tempfile
import time
from typing import Any

import yaml

HERMES_HOME = Path(os.environ.get("HERMES_HOME", "{{ hermes_home }}"))
CONFIG_DIR = Path(os.environ.get("HERMES_CONFIG_DIR", "{{ hermes_config_dir }}"))
SERVICE_USER = os.environ.get("HERMES_USER", "{{ hermes_user }}")
SERVICE_GROUP = os.environ.get("HERMES_GROUP", "{{ hermes_group }}")
VENV_PATH = Path(os.environ.get("HERMES_VENV_PATH", "{{ hermes_venv_path }}"))

RESTART_PREFIXES = ("config/", "profiles/", "plugins/", "rules/", "kanban/", "cron/")


def uid_gid() -> tuple[int, int]:
    return pwd.getpwnam(SERVICE_USER).pw_uid, grp.getgrnam(SERVICE_GROUP).gr_gid


def chown_tree(path: Path) -> None:
    uid, gid = uid_gid()
    if path.is_symlink():
        os.lchown(path, uid, gid)
        return
    if path.exists():
        os.chown(path, uid, gid)
    if path.is_dir():
        for child in path.rglob("*"):
            try:
                if child.is_symlink():
                    os.lchown(child, uid, gid)
                else:
                    os.chown(child, uid, gid)
            except FileNotFoundError:
                pass


def load_yaml(path: Path, fallback: Any = None) -> Any:
    if fallback is None:
        fallback = {}
    if not path.exists():
        return fallback
    data = yaml.safe_load(path.read_text(encoding="utf-8"))
    return fallback if data is None else data


def deep_merge(base: Any, desired: Any) -> Any:
    if isinstance(base, dict) and isinstance(desired, dict):
        merged = dict(base)
        for key, value in desired.items():
            merged[key] = deep_merge(merged.get(key), value)
        return merged
    return desired


def atomic_write_text(path: Path, content: str, mode: int = 0o644) -> bool:
    path.parent.mkdir(parents=True, exist_ok=True)
    current = path.read_text(encoding="utf-8") if path.exists() else None
    if current == content:
        return False
    original_stat = path.stat() if path.exists() and not path.is_symlink() else None
    fd, tmp_name = tempfile.mkstemp(prefix=f".{path.name}.", suffix=".tmp", dir=str(path.parent), text=True)
    tmp = Path(tmp_name)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            handle.write(content)
        if original_stat is not None:
            os.chown(tmp, original_stat.st_uid, original_stat.st_gid)
            os.chmod(tmp, stat.S_IMODE(original_stat.st_mode))
        else:
            uid, gid = uid_gid()
            os.chown(tmp, uid, gid)
            os.chmod(tmp, mode)
        tmp.replace(path)
    finally:
        if tmp.exists():
            tmp.unlink()
    return True


def copy_file_if_changed(src: Path, dest: Path) -> bool:
    dest.parent.mkdir(parents=True, exist_ok=True)
    changed = not dest.exists() or not filecmp.cmp(src, dest, shallow=False)
    if not changed:
        return False
    shutil.copy2(src, dest)
    chown_tree(dest)
    return True


def backup_name(path: Path) -> Path:
    return path.with_name(f"{path.name}.pre-hermes-config.{int(time.time())}")


def sync_directory_contents(src: Path, dest: Path) -> bool:
    if not src.exists():
        return False
    changed = False
    dest.mkdir(parents=True, exist_ok=True)
    for child in src.rglob("*"):
        rel = child.relative_to(src)
        target = dest / rel
        if child.is_dir():
            if not target.exists():
                target.mkdir(parents=True, exist_ok=True)
                changed = True
        elif child.is_file():
            changed |= copy_file_if_changed(child, target)
    return changed


def migrate_to_symlink(name: str, restart_on_change: bool) -> tuple[bool, bool]:
    live = HERMES_HOME / name
    target = CONFIG_DIR / name
    target.mkdir(parents=True, exist_ok=True)
    changed = False
    restart = False
    if live.is_symlink():
        if live.resolve() == target.resolve():
            chown_tree(target)
            return False, False
        live.unlink()
        changed = True
    elif live.exists():
        changed |= sync_directory_contents(live, target)
        backup = backup_name(live)
        live.rename(backup)
        changed = True
    if not live.exists():
        live.symlink_to(target, target_is_directory=True)
        changed = True
    chown_tree(target)
    chown_tree(live)
    if changed and restart_on_change:
        restart = True
    return changed, restart


def apply_default_config() -> tuple[bool, bool]:
    desired_path = CONFIG_DIR / "config/default/config.yaml"
    if not desired_path.exists():
        return False, False
    config_path = HERMES_HOME / "config.yaml"
    current = load_yaml(config_path, {})
    desired = load_yaml(desired_path, {})
    if not isinstance(current, dict) or not isinstance(desired, dict):
        raise SystemExit("Hermes config/default/config.yaml and live config.yaml must be YAML mappings")
    merged = deep_merge(current, desired)
    rendered = yaml.safe_dump(merged, sort_keys=False, allow_unicode=True)
    changed = atomic_write_text(config_path, rendered, 0o600)
    return changed, changed


def replace_managed_block(path: Path, src: Path, start: str, end: str) -> bool:
    if not src.exists():
        return False
    block = src.read_text(encoding="utf-8").rstrip() + "\n"
    current = path.read_text(encoding="utf-8") if path.exists() else ""
    if start in current and end in current:
        before, rest = current.split(start, 1)
        _, after = rest.split(end, 1)
        new_text = before.rstrip() + "\n\n" + block + after.lstrip("\n")
    else:
        new_text = current.rstrip() + "\n\n" + block if current.strip() else block
    return atomic_write_text(path, new_text, 0o644)


def apply_rules() -> tuple[bool, bool]:
    changed = replace_managed_block(
        HERMES_HOME / "SOUL.md",
        CONFIG_DIR / "rules/default-SOUL.md",
        "<!-- HERMES-CONFIG-DEFAULT-CONTROL-PLANE:START -->",
        "<!-- HERMES-CONFIG-DEFAULT-CONTROL-PLANE:END -->",
    )
    return changed, changed


def apply_profiles() -> tuple[bool, bool]:
    profiles_root = CONFIG_DIR / "profiles"
    if not profiles_root.exists():
        return False, False
    changed = False
    live_root = HERMES_HOME / "profiles"
    live_root.mkdir(parents=True, exist_ok=True)
    for profile_dir in profiles_root.iterdir():
        if not profile_dir.is_dir():
            continue
        name = profile_dir.name
        live_profile = live_root / name
        live_profile.mkdir(parents=True, exist_ok=True)
        for filename in ("config.yaml", "profile.yaml", "SOUL.md"):
            src = profile_dir / filename
            if src.exists():
                changed |= copy_file_if_changed(src, live_profile / filename)
        env_yaml = profile_dir / "env.yaml"
        if env_yaml.exists():
            data = load_yaml(env_yaml, {})
            lines = ["# Managed from hermes-config profiles/%s/env.yaml" % name]
            for key, value in data.items():
                if isinstance(value, bool):
                    rendered = "true" if value else "false"
                else:
                    rendered = str(value)
                lines.append(f"{key}={rendered}")
            changed |= atomic_write_text(live_profile / ".env", "\n".join(lines) + "\n", 0o600)
    chown_tree(live_root)
    return changed, changed


def apply_kanban_policies() -> tuple[bool, bool]:
    src_root = CONFIG_DIR / "kanban/policies"
    if not src_root.exists():
        return False, False
    dest_root = HERMES_HOME / "kanban/policies"
    changed = sync_directory_contents(src_root, dest_root)
    chown_tree(dest_root)
    return changed, False


def apply_scripts() -> tuple[bool, bool]:
    src_root = CONFIG_DIR / "scripts"
    if not src_root.exists():
        return False, False
    dest_root = HERMES_HOME / "scripts"
    changed = sync_directory_contents(src_root, dest_root)
    for src in src_root.rglob("*"):
        if src.is_file() and os.access(src, os.X_OK):
            dest = dest_root / src.relative_to(src_root)
            if dest.exists():
                mode = stat.S_IMODE(dest.stat().st_mode)
                if not mode & 0o111:
                    dest.chmod(mode | 0o755)
                    changed = True
    chown_tree(dest_root)
    return changed, False


def apply_cron_definitions() -> tuple[bool, bool]:
    cron_root = CONFIG_DIR / "cron"
    if not cron_root.exists() or not VENV_PATH.exists():
        return False, False
    jobs_path = HERMES_HOME / "cron/jobs.json"
    before = jobs_path.read_text(encoding="utf-8") if jobs_path.exists() else ""
    try:
        from cron.jobs import create_job, parse_schedule, resolve_job_ref, update_job
    except Exception as exc:
        print(f"cron_apply_skipped={exc!r}")
        return False, False
    for path in sorted(cron_root.glob("*.yaml")):
        job = load_yaml(path, {})
        name = job["name"]
        schedule = job["schedule"]
        script = job.get("script")
        deliver = job.get("deliver", "discord")
        desired_schedule = parse_schedule(schedule)
        existing = resolve_job_ref(name)
        if existing is None:
            create_job(prompt=job.get("prompt", ""), schedule=schedule, name=name, deliver=deliver, script=script, no_agent=job.get("no_agent", True))
            continue
        updates = {}
        if existing.get("schedule") != desired_schedule:
            updates["schedule"] = schedule
        if existing.get("schedule_display") != desired_schedule.get("display", schedule):
            updates["schedule_display"] = desired_schedule.get("display", schedule)
        for key in ("prompt", "deliver", "script", "no_agent"):
            desired = job.get(key, "" if key == "prompt" else True if key == "no_agent" else None)
            if desired is not None and existing.get(key) != desired:
                updates[key] = desired
        if existing.get("skills") not in ([], None):
            updates["skills"] = []
            updates["skill"] = None
        if updates:
            update_job(existing["id"], updates)
    after = jobs_path.read_text(encoding="utf-8") if jobs_path.exists() else ""
    changed = before != after
    if jobs_path.exists():
        chown_tree(jobs_path.parent)
    return changed, False


def main() -> int:
    if not CONFIG_DIR.is_dir():
        raise SystemExit(f"missing hermes-config checkout: {CONFIG_DIR}")

    changed = False
    restart = False

    for name, restart_on_change in (("skills", False), ("memories", False), ("plugins", True)):
        step_changed, step_restart = migrate_to_symlink(name, restart_on_change)
        changed |= step_changed
        restart |= step_restart

    for func in (
        apply_default_config,
        apply_rules,
        apply_profiles,
        apply_kanban_policies,
        apply_scripts,
        apply_cron_definitions,
    ):
        step_changed, step_restart = func()
        changed |= step_changed
        restart |= step_restart

    print(f"apply_changed={str(changed).lower()}")
    print(f"restart_required={str(restart).lower()}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

#!/usr/bin/env bash
set -euo pipefail

export HERMES_HOME={{ hermes_home | quote }}
export HOME={{ hermes_home | quote }}
HERMES={{ (hermes_venv_path + '/bin/hermes') | quote }}
BOARDS=({% for board in hermes_kanban_boards %}{{ board.slug | quote }} {% endfor %})

printf 'Hermes Kanban daily diagnostics\n'
printf 'Generated: %s\n\n' "$(date -Is)"

printf '## Boards\n'
"$HERMES" kanban boards list || true
printf '\n'

for board in "${BOARDS[@]}"; do
  printf '## Board: %s\n' "$board"
  "$HERMES" kanban --board "$board" diagnostics || true
  printf '\n### Blocked / review-required\n'
  "$HERMES" kanban --board "$board" list --status blocked || true
  printf '\n### Running\n'
  "$HERMES" kanban --board "$board" list --status running || true
  printf '\n'
done
